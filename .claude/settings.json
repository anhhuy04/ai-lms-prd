{
  "mcpServers": {
   "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=vazhgunhcjdwlkbslroc",
      "autoApprove": [
        "get_tables",
        "get_table",
        "get_table_columns",
        "get_table_rows",
        "get_table_row",
        "get_table_row_by_id",
        "get_table_row_by_id",
        "search_docs",
        "list_extensions",
        "list_migrations",
        "apply_migration",
        "get_logs",
        "get_advisors",
        "get_project_url",
        "get_publishable_keys",
        "generate_typescript_types",
        "list_edge_functions",
        "get_edge_function",
        "deploy_edge_function",
        "create_branch",
        "list_branches",
        "delete_branch",
        "merge_branch",
        "reset_branch",
        "rebase_branch"
      ]
    },

    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@kazuph/mcp-fetch@latest"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github@latest"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT_HERE"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem@latest",
        "D:\\code\\Flutter_Android\\AI_LMS_PRD"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory@latest"
      ]
    }
  }
}
